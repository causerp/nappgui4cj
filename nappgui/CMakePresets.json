{
  "version": 3,
  "configurePresets": [
    {
      "name": "base",
      "hidden": true,
      "binaryDir": "${sourceDir}/build",
      "cacheVariables": {
        "BUILD_SHARED_LIBS": false,
        "CMAKE_BUILD_TYPE": "Release",
        "CMAKE_POSITION_INDEPENDENT_CODE": true,
        "NAPPGUI_SHARED": false,
        "NAPPGUI_DEMO": false,
        "NAPPGUI_WEB": false
      }
    },
    {
      "name": "clang",
      "displayName": "Clang",
      "inherits": "base",
      "cacheVariables": {
        "CMAKE_C_COMPILER": "clang",
        "CMAKE_CXX_COMPILER": "clang++"
      }
    },
    {
      "name": "gcc",
      "displayName": "GCC",
      "inherits": "base",
      "cacheVariables": {
        "CMAKE_C_COMPILER": "gcc",
        "CMAKE_CXX_COMPILER": "g++"
      }
    }
  ],
  "buildPresets": [
    {
      "name": "clang",
      "configurePreset": "clang"
    },
    {
      "name": "gcc",
      "configurePreset": "gcc"
    }
  ]
}